<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F3FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Dark Navy Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0D1B3E"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SAFEWALK"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:textColor="#4D9FFF"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start a Walk"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fill in your journey details"
                android:textSize="13sp"
                android:textColor="#80A0C0"/>

        </LinearLayout>

        <!-- Content Area with rounded top corners -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_content_area"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="100dp"
            android:layout_marginTop="-16dp">

            <!-- Destination Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DESTINATION"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:textColor="#8A9ABF"
                        android:layout_marginBottom="10dp"/>

                    <!-- Destination Input Row -->
                    <LinearLayout
                        android:id="@+id/layoutDestinationInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_input_field"
                        android:padding="12dp"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_location_pin"
                            android:background="@drawable/bg_pin_icon"
                            android:padding="4dp"
                            android:layout_marginEnd="10dp"/>

                        <EditText
                            android:id="@+id/etDestination"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Enter destination address"
                            android:textColorHint="#A0AEC0"
                            android:textColor="#1A237E"
                            android:textSize="14sp"
                            android:inputType="textPostalAddress"
                            android:background="@null"
                            android:padding="0dp"/>
                    </LinearLayout>

                    <!-- Quick Location Buttons -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Saved Locations"
                        android:textSize="11sp"
                        android:textColor="#8A9ABF"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <LinearLayout
                            android:id="@+id/btnHome"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_quick_btn"
                            android:padding="10dp"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_home"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Home"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#1A237E"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btnSchool"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_quick_btn"
                            android:padding="10dp"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_school"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="School"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#1A237E"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btnWork"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_quick_btn"
                            android:padding="10dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_work"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Work"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#1A237E"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Arrival Time Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EXPECTED ARRIVAL"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:textColor="#8A9ABF"
                        android:layout_marginBottom="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvArrivalTime"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="Tap to set time"
                            android:textColor="#1A237E"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_input_field"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <Button
                            android:id="@+id/btnPickTime"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:text="Pick time"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:backgroundTint="#1A237E"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            app:cornerRadius="12dp"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Guardians Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NOTIFY GUARDIANS"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:textColor="#8A9ABF"
                        android:layout_marginBottom="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Avatar Stack -->
                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <!-- Avatar 1 (back) -->
                            <TextView
                                android:id="@+id/avatarC"
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:text="J"
                                android:textColor="#1A237E"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:background="@drawable/bg_avatar_inactive"
                                android:layout_marginStart="24dp"/>

                            <!-- Avatar 2 (middle) -->
                            <TextView
                                android:id="@+id/avatarB"
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:text="R"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:background="@drawable/bg_avatar_secondary"
                                android:layout_marginStart="12dp"/>

                            <!-- Avatar 1 (front) -->
                            <TextView
                                android:id="@+id/avatarA"
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:text="M"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:background="@drawable/bg_avatar_primary"/>

                        </FrameLayout>

                        <!-- Add Guardian Button -->
                        <ImageView
                            android:id="@+id/btnAddGuardian"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:src="@drawable/ic_add"
                            android:background="@drawable/bg_avatar_add"
                            android:padding="10dp"
                            android:layout_marginStart="6dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <!-- Guardian Info -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/tvGuardianCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2 notified"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#1A237E"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mom, Ryan active"
                                android:textSize="11sp"
                                android:textColor="#8A9ABF"/>

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/btnManageGuardians"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_chevron_right"
                            android:clickable="true"
                            android:focusable="true"
                            app:tint="#C5CAEF" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Check-in Reminder Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CHECK-IN REMINDER"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:textColor="#8A9ABF"
                        android:layout_marginBottom="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_input_field"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Remind me every"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A237E"/>

                        <Spinner
                            android:id="@+id/spinnerCheckin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#1A237E"
                            android:background="@null"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Begin Walk Button -->
            <Button
                android:id="@+id/btnBeginWalk"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Begin Walk"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#1A237E"
                android:drawableEnd="@drawable/ic_arrow_right"
                android:drawablePadding="8dp"
                app:cornerRadius="18dp"/>


            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status"/>

            <TextView
                android:id="@+id/tvSubStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sub status"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>