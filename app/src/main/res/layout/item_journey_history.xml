<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp"
    android:layout_marginBottom="8dp"
    android:elevation="2dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">

        <TextView android:id="@+id/tvJourneyDest"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Destination"
            android:textSize="15sp" android:textStyle="bold" android:textColor="#1A237E"/>

        <TextView android:id="@+id/tvJourneyAlerts"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Safe"
            android:textSize="12sp" android:textColor="#2E7D32"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="4dp">

        <TextView android:id="@+id/tvJourneyDist"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0.00 km" android:textSize="13sp" android:textColor="#424242"/>

        <TextView android:id="@+id/tvJourneyDuration"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 min" android:textSize="13sp" android:textColor="#424242"/>

    </LinearLayout>

    <TextView android:id="@+id/tvJourneyDate"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Date"
        android:textSize="11sp" android:textColor="#9E9E9E"
        android:layout_marginTop="4dp"/>

</LinearLayout>