<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF4FF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HEADER ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0D1B3E"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:paddingTop="36dp"
                android:paddingBottom="18dp">

                <!-- Status bar row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="9:41"
                        android:textColor="#B8C4D8"
                        android:textSize="11sp"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● ● ●"
                        android:textColor="#B8C4D8"
                        android:textSize="11sp"
                        android:fontFamily="monospace"/>

                </LinearLayout>

                <!-- Name + Avatar row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SAFEWALK"
                            android:textColor="#4D9FFF"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:letterSpacing="0.12"
                            android:fontFamily="monospace"/>

                        <TextView
                            android:id="@+id/tvGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Good evening, Janel"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                    <!-- Avatar circle -->
                    <FrameLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp">

                        <TextView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:text="JA"
                            android:textColor="#A0BBD8"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/bg_avatar"/>

                    </FrameLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ── CONTENT AREA ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="80dp">

                <!-- Status Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- Status dot + label -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <View
                                android:layout_width="9dp"
                                android:layout_height="9dp"
                                android:background="@drawable/bg_status_dot"
                                android:layout_marginRight="10dp"/>

                            <TextView
                                android:id="@+id/tvStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="You are safe"
                                android:textColor="#2A5C3B"
                                android:textSize="16sp"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvSubStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No active journey · Last walk 2h ago"
                            android:textColor="#9E9B94"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.03"
                            android:layout_marginLeft="19dp"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Guardians Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GUARDIANS"
                        android:textColor="#9E9B94"
                        android:textSize="11sp"
                        android:letterSpacing="0.08"
                        android:fontFamily="monospace"
                        android:layout_marginRight="12dp"/>

                    <!-- Guardian avatar: Mom -->
                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:text="M"
                        android:textColor="#A0BBD8"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_guardian_blue"
                        android:layout_marginRight="6dp"/>

                    <!-- Guardian avatar: Roommate -->
                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:text="R"
                        android:textColor="#9EC49E"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_guardian_green"
                        android:layout_marginRight="6dp"/>

                    <!-- Add guardian -->
                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:text="+"
                        android:textColor="#9E9B94"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@drawable/bg_guardian_gray"/>

                </LinearLayout>

                <!-- Map Preview Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#D8E4F0"
                    android:layout_marginBottom="14dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Map view replaces this in production -->
                        <com.google.android.gms.maps.MapView
                            android:id="@+id/mapPreview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"/>

                        <!-- Location chip overlay -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current location"
                            android:textColor="#4A5568"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:background="@drawable/bg_chip_white"
                            android:paddingLeft="10dp"
                            android:paddingRight="10dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="10dp"/>

                    </FrameLayout>

                </androidx.cardview.widget.CardView>

                <!-- Start Walk Button -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnStartWalk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1B2B4B"
                    android:layout_marginBottom="10dp"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="READY TO GO?"
                                android:textColor="#B8C4D8"
                                android:textSize="11sp"
                                android:letterSpacing="0.1"
                                android:fontFamily="monospace"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Start walk"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:layout_marginTop="4dp"/>

                        </LinearLayout>

                        <!-- Arrow icon circle -->
                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_icon_circle_blue">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_arrow_right"
                                android:layout_gravity="center"
                                app:tint="#7AAED4" />

                        </FrameLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Panic / SOS Button -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnPanic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#8B1A1A"
                    android:layout_marginBottom="10dp"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingLeft="18dp"
                        android:paddingRight="18dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="EMERGENCY"
                                android:textColor="#F5ADAD"
                                android:textSize="11sp"
                                android:letterSpacing="0.1"
                                android:fontFamily="monospace"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Panic / SOS"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:layout_marginTop="3dp"/>

                        </LinearLayout>

                        <!-- Shield icon circle -->
                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_circle_red">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_shield"
                                android:layout_gravity="center"
                                app:tint="#F5ADAD" />

                        </FrameLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Bottom Action Cards Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <!-- Manage Guardians Card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnGuardians"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFFFF"
                        android:layout_marginRight="5dp"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_people"
                                android:layout_marginBottom="8dp"
                                app:tint="#4A6D9C" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GUARDIANS"
                                android:textColor="#9E9B94"
                                android:textSize="11sp"
                                android:letterSpacing="0.06"
                                android:fontFamily="monospace"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Manage"
                                android:textColor="#2D2C28"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp"/>

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <!-- Walk History Card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnHistory"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFFFF"
                        android:layout_marginLeft="5dp"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_history"
                                android:layout_marginBottom="8dp"
                                app:tint="#3E8A58" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="HISTORY"
                                android:textColor="#9E9B94"
                                android:textSize="11sp"
                                android:letterSpacing="0.06"
                                android:fontFamily="monospace"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Past walks"
                                android:textColor="#2D2C28"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp"/>

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ── BOTTOM NAVIGATION ── -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_selector"
        app:itemTextColor="@color/bottom_nav_selector"
        app:labelVisibilityMode="labeled"
        app:elevation="8dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>